---
interface Props {
  lang?: string;
}

const { lang = 'en' } = Astro.props;
const isKo = lang === 'ko';

const copy = isKo
  ? {
      title: '구독하기',
      hint: '가끔 새 에세이 한 편, 메일로 전해드려요.',
      placeholder: 'you@domain.com',
      button: '구독',
      submitting: '구독 처리 중…',
      success: '구독 완료. 감사합니다.',
      already: '이미 구독 중이에요. 감사합니다.',
      invalid: '이메일 주소를 입력해주세요.',
      network: '네트워크 오류예요. 다시 시도해주세요.',
      generic: '구독에 실패했어요. 잠시 후 다시 시도해주세요.',
    }
  : {
      title: 'Subscribe',
      hint: 'An occasional essay, delivered to your inbox.',
      placeholder: 'you@domain.com',
      button: 'Join',
      submitting: 'Subscribing…',
      success: 'Subscribed — thanks.',
      already: "You're already on the list — thanks.",
      invalid: 'Please enter your email.',
      network: 'Network error. Please try again.',
      generic: 'Subscription failed. Please try again later.',
    };
---

<form
  class="subscribe-form"
  data-subscribe-form
  data-msg-submitting={copy.submitting}
  data-msg-success={copy.success}
  data-msg-already={copy.already}
  data-msg-invalid={copy.invalid}
  data-msg-network={copy.network}
  data-msg-generic={copy.generic}
  aria-label={copy.title}
>
  <label class="subscribe-form__label" for="subscribe-email">
    <span class="subscribe-form__title">{copy.title}</span>
    <span class="subscribe-form__hint">{copy.hint}</span>
  </label>
  <div class="subscribe-form__row">
    <input
      id="subscribe-email"
      class="subscribe-form__input"
      type="email"
      name="email"
      autocomplete="email"
      placeholder={copy.placeholder}
      required
    />
    <button type="submit" class="subscribe-form__button">{copy.button}</button>
  </div>
  <p class="subscribe-form__status" data-subscribe-status aria-live="polite"></p>
</form>

<script is:inline>
  (() => {
    const form = document.querySelector('[data-subscribe-form]');
    if (!(form instanceof HTMLFormElement)) return;

    const status = form.querySelector('[data-subscribe-status]');
    const input = form.querySelector('input[name="email"]');
    const button = form.querySelector('button[type="submit"]');
    const msg = {
      submitting: form.dataset.msgSubmitting ?? 'Subscribing…',
      success: form.dataset.msgSuccess ?? 'Subscribed.',
      already: form.dataset.msgAlready ?? "You're already on the list.",
      invalid: form.dataset.msgInvalid ?? 'Please enter your email.',
      network: form.dataset.msgNetwork ?? 'Network error.',
      generic: form.dataset.msgGeneric ?? 'Subscription failed.',
    };

    const setStatus = (message, tone) => {
      if (!(status instanceof HTMLElement)) return;
      status.textContent = message;
      status.dataset.tone = tone;
    };

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!(input instanceof HTMLInputElement) || !(button instanceof HTMLButtonElement)) return;

      const email = input.value.trim();
      if (!email) {
        setStatus(msg.invalid, 'error');
        return;
      }

      button.disabled = true;
      setStatus(msg.submitting, 'info');

      try {
        const response = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        const data = await response.json().catch(() => ({}));

        if (response.ok) {
          form.reset();
          setStatus(data.alreadySubscribed ? msg.already : msg.success, 'success');
        } else {
          setStatus(data.error ?? msg.generic, 'error');
        }
      } catch {
        setStatus(msg.network, 'error');
      } finally {
        button.disabled = false;
      }
    });
  })();
</script>
